# ============================================================
# WELTENBIBLIOTHEK – Umgebungsvariablen (Vorlage)
# ============================================================
# 1. Diese Datei kopieren: cp .env.local.example .env.local
# 2. .env.local mit deinen echten Werten befüllen
# 3. NIEMALS .env.local in das Repository committen!
#    (bereits in .gitignore eingetragen)
# ============================================================

# --- Supabase (https://supabase.com/dashboard) ---
# Projekt-URL (Settings > API > Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://DEIN_PROJEKT.supabase.co

# Anonymer Schlüssel – öffentlich (Settings > API > anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service Role Key – geheim! (Settings > API > service_role)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- App ---
NEXT_PUBLIC_APP_NAME=Weltenbibliothek
NEXT_PUBLIC_APP_URL=https://weltenbibliothek.pages.dev

# --- Cloudflare (https://dash.cloudflare.com/) ---
# API Token (nur für lokale Deployment-Skripte benötigt)
# Scopes: Workers Scripts: Edit, Account Settings: Read
CLOUDFLARE_API_TOKEN=<dein-api-token>
CLOUDFLARE_ACCOUNT_ID=<dein-account-id>
CLOUDFLARE_PROJECT_NAME=weltenbibliothek

# Optionale Cloudflare Worker URL für erweiterte API-Features
# CLOUDFLARE_WORKER_URL=https://weltenbibliothek.<subdomain>.workers.dev
